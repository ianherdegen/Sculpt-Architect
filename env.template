# ============================================================================
# TURSO ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your credentials
# ============================================================================

# Turso Database (required for API server)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# JWT secret for auth tokens (required in production)
JWT_SECRET=change-this-to-a-long-random-string

# App URL (used for magic link emails)
APP_URL=http://localhost:3000

# API base URL for local file uploads (dev only)
API_BASE_URL=http://localhost:3001

# Vercel Blob storage (optional - for production image uploads)
# BLOB_READ_WRITE_TOKEN=vercel_blob_token

# Resend email (optional - for magic link auth in production)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=noreply@yourdomain.com

# Frontend (optional - defaults to /api proxy)
# VITE_API_URL=/api
