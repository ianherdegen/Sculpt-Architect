{
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "installCommand": "yarn install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/route"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/route?__path=/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
